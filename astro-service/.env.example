# --- Service ---
LOG_LEVEL=INFO

# --- Nominatim ---
# Primary: self-hosted regional instance (CIS + Europe).
NOMINATIM_URL=http://localhost:8080
# Fallback for other regions / rest of world. Empty = primary only.
# If this is the public OSM instance, NOMINATIM_USER_AGENT MUST carry a real
# contact or it returns 403.
NOMINATIM_FALLBACK_URL=
NOMINATIM_USER_AGENT=astro-service/1.0
GEOCODING_TIMEOUT=10.0
GEOCODING_LANGUAGE=ru

# --- Ephemeris ---
# House system: P=Placidus, K=Koch, W=Whole Sign, R=Regiomontanus, ...
HOUSES_SYSTEM=P
# Zodiac type: Tropic | Sidereal
ZODIAC_TYPE=Tropic
