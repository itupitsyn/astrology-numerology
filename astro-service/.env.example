# --- Service ---
LOG_LEVEL=INFO

# --- Local Nominatim (self-hosted; no third-party geocoding APIs) ---
NOMINATIM_URL=http://localhost:8080
NOMINATIM_USER_AGENT=astro-service/1.0
GEOCODING_TIMEOUT=10.0
GEOCODING_LANGUAGE=ru

# --- Ephemeris ---
# House system: P=Placidus, K=Koch, W=Whole Sign, R=Regiomontanus, ...
HOUSES_SYSTEM=P
# Zodiac type: Tropic | Sidereal
ZODIAC_TYPE=Tropic
