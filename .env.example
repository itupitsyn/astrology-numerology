# Copy to .env on the server (it is gitignored). docker compose reads it automatically.

# --- Postgres ---
# CHANGE THIS in production.
POSTGRES_PASSWORD=astro

# --- Web ---
WEB_PORT=3000

# --- LLM (external llama.cpp, OpenAI-compatible) ---
# Required. The model id is auto-detected from the server's /v1/models.
NUXT_LLM_BASE_URL=
# Optional bearer token, if the LLM server requires auth.
NUXT_LLM_API_KEY=

# --- Geocoding (public Nominatim for now) ---
NOMINATIM_URL=https://nominatim.openstreetmap.org
# Put a real contact here per Nominatim usage policy.
NOMINATIM_USER_AGENT=astro-numerology-app/1.0 (you@example.com)
GEOCODING_LANGUAGE=ru
